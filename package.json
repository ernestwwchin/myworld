{
  "name": "myworld",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 3100 --strictPort",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && vitest run",
    "test:contracts": "vitest run tests/contracts/run-contracts.test.ts",
    "test:unit": "vitest run tests/unit",
    "test:unit:watch": "vitest tests/unit",
    "test:e2e": "npm run build && playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:headed": "npm run build && playwright test --config tests/e2e/playwright.config.ts --headed --workers=1"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "js-yaml": "^4.1.1",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/js-yaml": "^4.0.9",
    "jsdom": "^29.0.2",
    "svelte": "^5.55.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  }
}
