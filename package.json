{
  "name": "myworld",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "postinstall": "npm run e2e:install:browsers",
    "test": "npm run test:contracts && npm run test:unit",
    "test:contracts": "node tests/contracts/run-contracts.js",
    "test:unit": "node --test tests/unit/pure/**/*.test.js tests/unit/sandbox/**/*.test.js",
    "e2e:install:browsers": "playwright install",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:headed": "playwright test --config tests/e2e/playwright.config.js --headed --workers=1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.2.1",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "zod": "^4.3.6"
  }
}
