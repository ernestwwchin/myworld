# Tofu/Terraform — state in S3, local dirs ignored
**/.terraform/
**/terraform.tfstate*
*.tfplan

# Secrets — never commit these
*.secret.*
.sops.yaml

# AI agent config — local settings may contain infrastructure identifiers
.claude/
!.claude/settings.json
!.claude/commands/
!.claude/commands/*

test-results/
playwright-report/
node_modules/
dist/
public/assets/*.zip
public/assets/_downloads/
public/assets/_staging/
**/_MACOSX/
**/.DS_Store
scratch/

# Obsidian — workspace state is machine-specific; plugin binaries are re-fetched from manifests
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/plugins/*/data.json

# commit graph outputs, ignore the extraction cache and regenerable obsidian vault
graphify-out/cache/
graphify-out/obsidian/temp.hson
